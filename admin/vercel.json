{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev:frontend",
  "installCommand": "npm install",
  "framework": "vite",
  "alias": ["admin.longsang.org"],
  "rewrites": [
    {
      "source": "/api/youtube-channels",
      "destination": "/api/youtube-channels.js"
    },
    {
      "source": "/api/youtube-channels/(.*)",
      "destination": "/api/youtube-channels.js?path=$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store" }
      ]
    }
  ]
}
