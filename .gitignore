# ═══════════════════════════════════════════════════
# LONGSANG MASTER ADMIN — .gitignore
# Monorepo: admin + youtube-crew + api + services
# ═══════════════════════════════════════════════════

# ── Dependencies ──
node_modules/
.venv/
__pycache__/

# ── Environment / Secrets ──
.env
.env.local
.env.production
*.env

# ── Build outputs ──
dist/
build/
.next/
.output/
*.tsbuildinfo

# ── OS & Editor ──
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
*.code-workspace
.windsurf/
.vscode/
.dev-pids
.copilot*

# ── Logs & Temp ──
logs/
*.log
npm-debug.log*
.tmp/
temp/
output/

# ── Media assets (large, generated) ──
*.mp4
*.mp3
*.wav
*.FLAC
*.flac

# ── Heavy ML assets ──
pretrained/
*.pth
*.onnx
*.bin
*.safetensors
*.ckpt

# ── YouTube Crew: knowledge base (serve from Supabase/local) ──
services/youtube-crew/src/knowledge/transcripts*/
services/youtube-crew/src/knowledge/thuattaivan/
services/youtube-crew/src/knowledge/akbimatluatngam/
services/youtube-crew/src/knowledge/hormozi/
services/youtube-crew/data/*.json
services/youtube-crew/data/*.txt
!services/youtube-crew/data/calendar.json

# ── Services: data-heavy / local-only ──
services/bulk-video/
services/fish-speech-venv/
services/temp-demucs/
services/mcp-server/.venv/
services/mcp-server/generated_images/
services/mcp-server/generated_videos/
services/fish-speech/
services/voxcpm-tts/pretrained/
services/voxcpm-tts/repo/
services/lyblack-content/videos/
services/lyblack-content/assets/
services/lyblack-content/fish-speech/
services/lyblack-content/fish-speech-tts/

# ── API Gateway (has own .git — manage separately) ──
api/

# ── Moltbook Agent (has own .git — github.com/longsang063/moltbook-agent) ──
services/moltbook-agent/

# ── Archive: old/stale projects ──
_archive/

# ── Reference: docs & skills (not code) ──
reference/

# ── Workflows: local automation ──
workflows/

# ── Legacy paths (cleanup after VS Code restart) ──
apps/

# ── Admin: exclude heavy non-frontend dirs ──
apps/admin/api/
apps/admin/supabase/
apps/admin/services/
apps/admin/brain-upgrade/
apps/admin/.github/
apps/admin/.husky/
apps/admin/templates/
**/package-lock.json
*.ps1

# ── State files ──
state/
*.state.json

# Travis AI temp configs (contain secrets)
tmp-render-travis.json
tmp-travis-env.json
tmp-*.json
